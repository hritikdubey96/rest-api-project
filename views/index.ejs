<!DOCTYPE html>
<html>
<head>
    <title>Users</title>
</head>
<body>

    <h1>All Users</h1>

    <ul>

        <% for(let user of users){ %>

         <li>
            <%= user.username %>

            <a href="/users/<%= user.id %>">
                View Profile
            </a>
        </li>

        <% } %>

    </ul>

</body>
</html>